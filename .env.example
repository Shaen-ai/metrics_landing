# Optional: Stripe Payment Link, Ko-fi, PayPal, etc. — shows donate CTA when set.
NEXT_PUBLIC_DONATE_URL=

# Main app (e.g. metrics platform) origin, no trailing slash. When set, the navbar shows Sign in (sign up is linked from the app login page).
# Local: metrics `npm run dev` is http://localhost:3000; landing uses port 3002 in package.json.
NEXT_PUBLIC_APP_URL=http://localhost:3000
