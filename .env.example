# --- Donate (footer + /pricing) ---
# Optional: Stripe Payment Link, Ko-fi, PayPal.me, etc. Footer and pricing show a donate CTA when set.
NEXT_PUBLIC_DONATE_URL=

# --- Subscription checkout ( /pricing “Get started” for paid tiers ) ---
# Create one Payment Link (or checkout URL) per tier × interval in Stripe; paste full https:// URLs here.
# Enterprise uses mailto (CONTACT_SUPPORT_EMAIL) — no env needed.
# Until Laravel webhooks sync plan_tier, assign tiers manually after purchase or wire Stripe webhooks.
NEXT_PUBLIC_CHECKOUT_STARTER_MONTHLY=
NEXT_PUBLIC_CHECKOUT_STARTER_ANNUAL=
NEXT_PUBLIC_CHECKOUT_BUSINESS_MONTHLY=
NEXT_PUBLIC_CHECKOUT_BUSINESS_ANNUAL=
NEXT_PUBLIC_CHECKOUT_BUSINESS_PRO_MONTHLY=
NEXT_PUBLIC_CHECKOUT_BUSINESS_PRO_ANNUAL=

# Main app (metrics platform) origin, no trailing slash. CTAs use APP_URL/login (“Get started”, “Sign in”).
# Local: metrics `npm run dev` → http://localhost:3000 (landing is often port 3002).
# Production builds: if unset, defaults to https://admin.tunzone.com (override here for staging previews).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: mailto target for footer “Contact”, about page, Enterprise CTA (defaults to support@tunzone.com).
# NEXT_PUBLIC_CONTACT_SUPPORT_EMAIL=
