# GA4 Measurement ID (public). Loaded in production builds only; see `.env.production`.
# Omit or leave empty in `.env.development` / `.env.local` so dev does not send hits.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog project API key (public client key; EU region). See PostHogProvider + /ingest proxy in next.config.ts.
# NEXT_PUBLIC_POSTHOG_KEY=

# --- Subscription checkout (/pricing “Get started”) ---
# Optional: override default (https://api.tunzone.com/api/billing/checkout baked in for production).
# Or set NEXT_PUBLIC_API_URL (e.g. https://api.example.com/api) — we append /billing/checkout.
NEXT_PUBLIC_BILLING_CHECKOUT_BASE_URL=http://localhost:8000/api/billing/checkout
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Main app (metrics platform) origin, no trailing slash. CTAs use APP_URL/login (“Get started”, “Sign in”).
# Local: metrics `npm run dev` → http://localhost:3000 (landing is often port 3002).
# Production builds: if unset, defaults to https://admin.tunzone.com (override here for staging previews).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vista B2C AI interior app — no trailing slash. Production defaults to https://vista.tunzone.com if unset.
# Local: vista `npm run dev` uses port 3003 by default (see vista/package.json).
NEXT_PUBLIC_VISTA_URL=http://localhost:3003

# Studio B2B admin app — no trailing slash. Production defaults to https://editor.tunzone.com if unset.
# Local: metrics_platform `npm run dev` uses port 3000 by default (see metrics_platform/package.json).
NEXT_PUBLIC_STUDIO_URL=http://localhost:3000

# Optional: mailto target for footer “Contact”, about page, Enterprise CTA (defaults to support@tunzone.com).
# NEXT_PUBLIC_CONTACT_SUPPORT_EMAIL=
